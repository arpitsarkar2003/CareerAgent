# Elevated secrets. This file documents required vars only — never commit
# actual values. Never expose these to apps/web or the browser.

SUPABASE_URL=
# Preferred (new API keys): sb_secret_…
SUPABASE_SECRET_KEY=
# Fallback only (legacy JWT service_role) if SUPABASE_SECRET_KEY is unset
# SUPABASE_SERVICE_ROLE_KEY=

CLERK_SECRET_KEY=
# Used to derive the JWT issuer / JWKS URL for Module 2+ route auth.
# Prefer CLERK_JWT_ISSUER if set; else decode from publishable key.
CLERK_PUBLISHABLE_KEY=
# CLERK_JWT_ISSUER=https://your-instance.clerk.accounts.dev
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json

# Origin allowed to call this API (CORS). Set to the deployed web URL in prod.
WEB_ORIGIN=http://localhost:3000

# AI_PROVIDER selects the adapter implementation in apps/api/ai/.
# Module 2 embeddings use Cloudflare Workers AI (free tier).
AI_PROVIDER=cloudflare

# Cloudflare Workers AI — free embeddings (no OpenRouter needed for Module 2).
# Dashboard → Workers & Pages → Overview → Account ID
CLOUDFLARE_ACCOUNT_ID=
# API Token with Workers AI — Read permission
# https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=
# Must match knowledge_chunks.embedding dims (1024 for bge-large-en-v1.5).
# Changing this requires a migration + re-embedding the whole knowledge base.
EMBEDDING_MODEL=@cf/baai/bge-large-en-v1.5

# Optional / Module 3+ chat providers (not required for Module 2 embeddings).
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
