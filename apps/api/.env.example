# Elevated secrets. This file documents required vars only — never commit
# actual values. Never expose these to apps/web or the browser.

SUPABASE_URL=
# Preferred (new API keys): sb_secret_…
SUPABASE_SECRET_KEY=
# Fallback only (legacy JWT service_role) if SUPABASE_SECRET_KEY is unset
# SUPABASE_SERVICE_ROLE_KEY=

CLERK_SECRET_KEY=
# Used to derive the JWT issuer / JWKS URL for Module 2+ route auth.
# Prefer CLERK_JWT_ISSUER if set; else decode from publishable key.
CLERK_PUBLISHABLE_KEY=
# CLERK_JWT_ISSUER=https://your-instance.clerk.accounts.dev
# CLERK_JWKS_URL=https://your-instance.clerk.accounts.dev/.well-known/jwks.json

# Origin allowed to call this API (CORS). Set to the deployed web URL in prod.
WEB_ORIGIN=http://localhost:3000

# AI_PROVIDER selects the adapter implementation in apps/api/ai/.
# Default (and only built-in implementation): cloudflare.
# Other values fail with a clear "provider not implemented" error.
AI_PROVIDER=cloudflare

# Cloudflare Workers AI — chat + embeddings (10k Neurons/day free allocation).
# Dashboard → Workers & Pages → Overview → Account ID
CLOUDFLARE_ACCOUNT_ID=
# API Token with Workers AI — Read permission
# https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# Chat and embedding models are configured separately so changing chat never
# silently invalidates knowledge_chunks vectors.
CHAT_MODEL=@cf/zai-org/glm-4.7-flash
# Must match knowledge_chunks.embedding dims (1024 for bge-large-en-v1.5).
# Changing this requires a migration + re-embedding the whole knowledge base.
EMBEDDING_MODEL=@cf/baai/bge-large-en-v1.5

# Daily Neuron budget (estimated from token counts). Cloudflare Paid does NOT
# auto-stop at 10k — this hard-stops Career Agent near the free allocation.
# Default 9000 (margin under Cloudflare's 10_000/day). Set 0 or off to disable.
AI_DAILY_NEURON_BUDGET=9000
# Optional path for the UTC-day counter JSON (default /tmp/...).
# AI_BUDGET_STATE_PATH=/tmp/careeragent_ai_neuron_budget.json

# Optional — reserved for a future second provider implementation (not built).
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
