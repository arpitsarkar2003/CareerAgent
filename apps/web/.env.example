# Browser-safe values (NEXT_PUBLIC_*). Never put Supabase or AI keys here.
#
# REQUIRED: NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY + CLERK_SECRET_KEY from the SAME
# Clerk app (Dashboard → API Keys). Empty publishable key causes keyless mode
# and Google sign-in / dashboard redirect loops (jwk-kid-mismatch).

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# Prevent Clerk from inventing a temporary keyless instance
NEXT_PUBLIC_CLERK_KEYLESS_DISABLED=1

# Server-only — same Clerk app as the publishable key. Never NEXT_PUBLIC_.
CLERK_SECRET_KEY=
